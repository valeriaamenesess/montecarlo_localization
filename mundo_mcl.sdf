<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="mcl_world">

    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>

    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>

    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
</plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Piso de 40 x 40 metros -->
    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>40 40 0.05</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>40 40 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bordes exteriores del mapa -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 20 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>40 0.75 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>40 0.75 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static>
      <pose>0 -20 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>40 0.75 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>40 0.75 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static>
      <pose>20 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.75 40 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.75 40 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static>
      <pose>-20 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.75 40 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.75 40 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Obstáculo 1: rectángulo de pixeles (200,200) a (300,300) -->
    <model name="obstacle_1">
      <static>true</static>
      <pose>-7.5 7.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5 5 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5 5 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Obstáculo 2: rectángulo de pixeles (500,400) a (600,600) -->
    <model name="obstacle_2">
      <static>true</static>
      <pose>7.5 -5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5 10 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5 10 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Obstáculo 3: rectángulo de pixeles (100,600) a (400,650) -->
    <model name="obstacle_3">
      <static>true</static>
      <pose>-7.5 -11.25 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>15 2.5 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>15 2.5 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Obstáculo 4: rectángulo de pixeles (600,100) a (700,150) -->
    <model name="obstacle_4">
      <static>true</static>
      <pose>12.5 13.75 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5 2.5 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5 2.5 1</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Robot diferencial simple con LiDAR -->
    <model name="mcl_robot">
    <pose>0 0 0.15 0 0 0</pose>

    <link name="base_link">
        <inertial>
        <mass>5.0</mass>
        <inertia>
            <ixx>0.1</ixx>
            <iyy>0.1</iyy>
            <izz>0.1</izz>
        </inertia>
        </inertial>

        <collision name="base_collision">
        <geometry>
            <box>
            <size>0.5 0.35 0.2</size>
            </box>
        </geometry>
        </collision>

        <visual name="base_visual">
        <geometry>
            <box>
            <size>0.5 0.35 0.2</size>
            </box>
        </geometry>
        <material>
            <ambient>0.1 0.1 1.0 1</ambient>
            <diffuse>0.1 0.1 1.0 1</diffuse>
        </material>
        </visual>

        <!-- LiDAR -->
        <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0.25 0 0 0</pose>
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <lidar>
            <scan>
            <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
            </horizontal>
            </scan>
            <range>
            <min>0.1</min>
            <max>20.0</max>
            <resolution>0.01</resolution>
            </range>
        </lidar>
        <always_on>true</always_on>
        <visualize>true</visualize>
        </sensor>
    </link>

    <!-- Rueda izquierda -->
    <link name="left_wheel">
        <pose>0 0.225 -0.05 -1.5708 0 0</pose>
        <inertial>
        <mass>0.5</mass>
        <inertia>
            <ixx>0.001</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
        </inertia>
        </inertial>

        <collision name="collision">
        <geometry>
            <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
            </cylinder>
        </geometry>
        </collision>

        <visual name="visual">
        <geometry>
            <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
            </cylinder>
        </geometry>
        <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
        </material>
        </visual>
    </link>

    <!-- Rueda derecha -->
    <link name="right_wheel">
        <pose>0 -0.225 -0.05 -1.5708 0 0</pose>
        <inertial>
        <mass>0.5</mass>
        <inertia>
            <ixx>0.001</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
        </inertia>
        </inertial>

        <collision name="collision">
        <geometry>
            <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
            </cylinder>
        </geometry>
        </collision>

        <visual name="visual">
        <geometry>
            <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
            </cylinder>
        </geometry>
        <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
        </material>
        </visual>
    </link>

    <!-- Rueda loca / caster -->
    <link name="caster">
        <pose>-0.2 0 -0.1 0 0 0</pose>
        <collision name="collision">
        <geometry>
            <sphere>
            <radius>0.05</radius>
            </sphere>
        </geometry>
        <surface>
            <friction>
            <ode>
                <mu>0.0</mu>
                <mu2>0.0</mu2>
            </ode>
            </friction>
        </surface>
        </collision>
        <visual name="visual">
        <geometry>
            <sphere>
            <radius>0.05</radius>
            </sphere>
        </geometry>
        <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
        </visual>
    </link>

    <!-- Joints de ruedas -->
    <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel</child>
        <axis>
        <xyz>0 0 1</xyz>
        <limit>
            <lower>-1e16</lower>
            <upper>1e16</upper>
        </limit>
        </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel</child>
        <axis>
        <xyz>0 0 1</xyz>
        <limit>
            <lower>-1e16</lower>
            <upper>1e16</upper>
        </limit>
        </axis>
    </joint>

    <!-- Plugin de robot diferencial -->
    <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">

        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>

        <wheel_separation>0.45</wheel_separation>
        <wheel_radius>0.1</wheel_radius>

        <odom_publish_frequency>30</odom_publish_frequency>

        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <tf_topic>/tf</tf_topic>

        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
    </plugin>

    </model>

  </world>
</sdf>